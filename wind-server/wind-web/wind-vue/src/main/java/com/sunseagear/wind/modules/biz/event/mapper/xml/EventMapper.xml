<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sunseagear.wind.modules.biz.event.mapper.EventMapper" >

    <sql id="Base_Column_List" >
      a.*,
      b.realname as `user.realname`,
      o.name as `organization.name`

    </sql>
    <sql id="Table_Joins">
      left join sys_user b on b.id = a.user_id
      left join sys_organization o on o.id = a.organization_id
    </sql>
    <select
       id="selectPage"
       resultType="com.sunseagear.wind.modules.biz.event.entity.Event">
        select
        <include refid="Base_Column_List"/>
        from biz_event a
        <include refid="Table_Joins"/>
        <if test="ew.sqlSegment != '' and ew.sqlSegment != null">
            <if test="!ew.isEmptyOfWhere">
                <where>
                    ${ew.sqlSegment}
                </where>
            </if>
            <if test="ew.isEmptyOfWhere">
                ${ew.sqlSegment}
            </if>
        </if>
    </select>
    <select
       id="selectById"
       resultType="com.sunseagear.wind.modules.biz.event.entity.Event">
        select
        <include refid="Base_Column_List"/>
        from biz_event a
        <include refid="Table_Joins"/>
        where a.id = #{id,jdbcType=VARCHAR}
    </select>
</mapper>