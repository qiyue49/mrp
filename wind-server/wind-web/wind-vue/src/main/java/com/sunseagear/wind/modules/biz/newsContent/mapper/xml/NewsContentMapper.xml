<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sunseagear.wind.modules.biz.newsContent.mapper.NewsContentMapper">

    <sql id="Base_Column_List">
      a.*

    </sql>
    <sql id="Table_Joins">
    </sql>
    <insert id="insertCollection">
        insert into biz_news_collection (user_id, news_id) value (#{userId},#{newsId})
    </insert>
    <delete id="removeCollection">
         delete from biz_news_collection where news_id = #{newsId} and user_id = #{userId}
    </delete>


    <select
        id="selectPage"
        resultType="com.sunseagear.wind.modules.biz.newsContent.entity.NewsContent">
        SELECT a.*,b.newsType_name
        FROM
        biz_newscontent a LEFT JOIN biz_newsType b
        ON a.newsType_id = b.id
        <if test="ew.sqlSegment != '' and ew.sqlSegment != null">
            <where>
                ${ew.sqlSegment}
            </where>
        </if>
    </select>

    <select
        id="isCollection"
        resultType="java.lang.Boolean">
        select count(*) from biz_news_collection where news_id = #{newsId} and user_id = #{userId}
    </select>

    <select
        id="myCollection"
        resultType="com.sunseagear.wind.modules.biz.newsContent.entity.NewsContent">
        SELECT a.*,b.newsType_name
        FROM
        biz_newscontent a
        LEFT JOIN biz_newsType b ON a.newsType_id = b.id
        LEFT JOIN biz_news_collection c ON a.id = c.news_id
        <if test="ew.sqlSegment != '' and ew.sqlSegment != null">
            <where>
                ${ew.sqlSegment}
            </where>
        </if>

    </select>

</mapper>
